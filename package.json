{
  "name": "shipflow",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:push": "pnpm --filter @shipflow/db db:push",
    "db:generate": "pnpm --filter @shipflow/db db:generate",
    "db:studio": "pnpm --filter @shipflow/db db:studio"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "prettier": "^3.3.3",
    "tsx": "^4.22.4",
    "turbo": "^2.1.0",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}