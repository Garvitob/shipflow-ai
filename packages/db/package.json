    "provision": "dotenv -e ../../.env -- tsx scripts/provision.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.19.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}