{
  "name": "@shipflow/db",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
