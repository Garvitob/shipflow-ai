generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  ADMIN
  PM
  SENIOR_ENG
  DEVELOPER
  CLIENT
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum ProjectType {
  EXISTING
  NEW
}

enum RequestType {
  BUG
  CRITICAL_BUG
  FEATURE
  IMPROVEMENT
  OTHER
}

enum FeatureStatus {
  SUBMITTED
  DISCOVERY
  PRD_DRAFT
  PRD_APPROVED
  PLANNING
  IN_DEV
  IN_REVIEW
  FIX_NEEDED
  PENDING_APPROVAL
  SHIPPED
  REJECTED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum AssigneeType {
  HUMAN
  AI_AGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum PRStatus {
  OPEN
  IN_REVIEW
  NEEDS_FIX
  APPROVED
  MERGED
}

enum ReviewStatus {
  RUNNING
  COMPLETE
  FAILED
}

enum AnalysisStatus {
  IDLE
  RUNNING
  COMPLETE
  FAILED
}

enum Severity {
  S1
  S2
  S3
  S4
  S5
}

enum FindingCategory {
  SECURITY
  CORRECTNESS
  PERFORMANCE
  REQUIREMENT
  EDGE_CASE
  CODE_QUALITY
}

enum FindingStatus {
  OPEN
  OVERRIDE_PENDING
  CLEARED
  ESCALATED
  REJECTED
}

// ─── MODELS ──────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  credits   Int      @default(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  Membership[]
  projects     Project[]
  subscription Subscription?
  auditLogs    AuditLog[]

  @@index([slug])
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        Role
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
  @@index([workspaceId, role])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // App relations
  memberships    Membership[]
  projectMembers ProjectMember[]
  tasks          Task[]
  justifications Justification[]

  // BetterAuth relations
  sessions Session[]
  accounts Account[]

  @@index([email])
  @@map("user")
}

model Project {
  id               String      @id @default(cuid())
  workspaceId      String
  name             String
  description      String
  techStack        String
  existingFeatures String
  businessGoals    String
  targetUsers      String
  projectType      ProjectType @default(EXISTING)
  codebaseSummary  String?
  ticketSeq        Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureRequests FeatureRequest[]
  gitHubRepo      GitHubRepo?
  projectMembers  ProjectMember[]

  @@index([workspaceId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      Role
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([projectId, role])
}

model FeatureRequest {
  id             String        @id @default(cuid())
  projectId      String
  clientId       String
  ticketNumber   Int?
  type           RequestType
  severity       Int?
  requestedDays  Int?
  title          String
  rawDescription String
  status         FeatureStatus @default(SUBMITTED)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project              Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversationMessages ConversationMessage[]
  prd                  Prd?

  @@unique([projectId, ticketNumber])
  @@index([projectId])
  @@index([clientId])
  @@index([projectId, status])
  @@index([status])
}

model ConversationMessage {
  id               String      @id @default(cuid())
  featureRequestId String
  role             MessageRole
  content          String
  createdAt        DateTime    @default(now())

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@index([featureRequestId])
  @@index([featureRequestId, createdAt])
}

model Prd {
  id               String    @id @default(cuid())
  featureRequestId String    @unique
  version          Int       @default(1)
  problemStatement String
  goals            String
  nonGoals         String
  userStories      String
  edgeCases        String
  successMetrics   String
  approvedByPmId   String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  featureRequest     FeatureRequest        @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  acceptanceCriteria AcceptanceCriterion[]
  tasks              Task[]

  @@index([featureRequestId])
}

model AcceptanceCriterion {
  id          String @id @default(cuid())
  prdId       String
  title       String
  description String
  order       Int

  prd      Prd       @relation(fields: [prdId], references: [id], onDelete: Cascade)
  tasks    Task[]
  findings Finding[]

  @@index([prdId])
  @@index([prdId, order])
}

model Task {
  id                    String       @id @default(cuid())
  prdId                 String
  acceptanceCriterionId String
  title                 String
  description           String
  complexity            String
  assignedToId          String?
  assigneeType          AssigneeType @default(HUMAN)
  assignedBySeniorEngId String?
  status                TaskStatus   @default(TODO)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  prd                 Prd                 @relation(fields: [prdId], references: [id], onDelete: Cascade)
  acceptanceCriterion AcceptanceCriterion @relation(fields: [acceptanceCriterionId], references: [id])
  assignedTo          User?               @relation(fields: [assignedToId], references: [id])

  @@index([prdId])
  @@index([acceptanceCriterionId])
  @@index([assignedToId])
  @@index([prdId, status])
}

model GitHubRepo {
  id                  String         @id @default(cuid())
  projectId           String         @unique
  repoFullName        String
  installationId      String?
  defaultBranch       String         @default("main")
  analysisStatus      AnalysisStatus @default(IDLE)
  analysisProgress    Json?
  analysisStartedAt   DateTime?
  analysisCompletedAt DateTime?
  createdAt           DateTime       @default(now())

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pullRequests PullRequest[]

  @@index([projectId])
  @@index([repoFullName])
}

model PullRequest {
  id                 String       @id @default(cuid())
  repoId             String
  featureRequestId   String
  prNumber           Int
  title              String
  branchName         String
  commitSha          String
  authorType         AssigneeType
  authorGithubHandle String
  status             PRStatus     @default(OPEN)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  repo            GitHubRepo       @relation(fields: [repoId], references: [id], onDelete: Cascade)
  reviewSnapshots ReviewSnapshot[]

  @@index([repoId])
  @@index([featureRequestId])
  @@index([status])
  @@index([repoId, prNumber])
}

model ReviewSnapshot {
  id            String   @id @default(cuid())
  pullRequestId String
  commitSha     String
  prdVersion    Int
  diffSnapshot  String
  createdAt     DateTime @default(now())

  pullRequest PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  reviewRuns  ReviewRun[]

  @@index([pullRequestId])
  @@index([pullRequestId, createdAt])
}

model ReviewRun {
  id               String       @id @default(cuid())
  snapshotId       String
  modelAResult     String
  modelBResult     String
  reconciledResult String
  status           ReviewStatus @default(RUNNING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  snapshot ReviewSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  findings Finding[]

  @@index([snapshotId])
  @@index([status])
}

model Finding {
  id                    String          @id @default(cuid())
  reviewRunId           String
  acceptanceCriterionId String
  severity              Severity
  category              FindingCategory
  title                 String
  description           String
  quotedEvidence        String
  status                FindingStatus   @default(OPEN)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  reviewRun           ReviewRun           @relation(fields: [reviewRunId], references: [id], onDelete: Cascade)
  acceptanceCriterion AcceptanceCriterion @relation(fields: [acceptanceCriterionId], references: [id])
  justifications      Justification[]

  @@index([reviewRunId])
  @@index([acceptanceCriterionId])
  @@index([reviewRunId, severity])
  @@index([reviewRunId, status])
}

model Justification {
  id                 String    @id @default(cuid())
  findingId          String
  authorId           String
  reason             String
  aiValidationResult String?
  validatedAt        DateTime?
  createdAt          DateTime  @default(now())

  finding Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([findingId])
  @@index([authorId])
}

model Subscription {
  id                     String    @id @default(cuid())
  workspaceId            String    @unique
  razorpaySubscriptionId String
  plan                   Plan
  creditsRemaining       Int
  repoLimit              Int
  status                 SubStatus
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([razorpaySubscriptionId])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String
  action      String
  entityType  String
  entityId    String
  metadata    String?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
}

// ─── BETTERAUTH MODELS ───────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
